NODE_ENV=development
PORT=3001
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,https://loohii.com"
# Frontend API base. Leave empty for same-origin /api reverse proxy in production,
# or set explicitly, for example: VITE_API_URL="https://loohii.com"
VITE_API_URL=""
VITE_DEV_API_PROXY="http://localhost:3001"
VITE_AUTH_MOCK_MODE="false"

# Prisma/PostgreSQL
DATABASE_URL="postgresql://loohii:loohii_dev_password@localhost:5432/loohii?schema=public"

# Redis-backed queues, job locks, and short-lived agent state.
REDIS_URL="redis://localhost:6379"

# Auth：全站只认 aijiekou 平台 JWT（《P0-loohii积分统一接口契约》§2）。
# 服务端拿 Bearer token 调 {AIJIEKOU_API_BASE}/v1/me 验真，不再需要本地 JWT_SECRET。
AIJIEKOU_API_BASE="https://api.aijiekou.online"
AIJIEKOU_TIMEOUT_MS="10000"
# /v1/me 验真结果缓存（毫秒），0 = 禁用缓存
AIJIEKOU_ME_CACHE_TTL_MS="60000"
# 前端直连平台登录接口的 base
VITE_AIJIEKOU_API_BASE="https://api.aijiekou.online"

# Payment provider placeholders.
PAYMENT_WEBHOOK_SECRET=""

# AI provider placeholders.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_IMAGE_MODEL="gpt-image-1"
MODEL_CONFIG_ENCRYPTION_KEY="replace-with-32-plus-random-bytes"
# Optional comma-separated allowlist for users who can manage global provider/model settings.
# Leave empty for single-user development.
MODEL_CONFIG_ADMIN_EMAILS=""

# Optional local Jimeng/Dreamina reverse-engineered API service.
# Run: docker run -d --name jimeng-api -p 127.0.0.1:5100:5100 --restart unless-stopped ghcr.io/iptag/jimeng-api:latest
JIMENG_API_BASE_URL="http://127.0.0.1:5100"
JIMENG_API_TIMEOUT_MS="900000"
RUNWAY_API_KEY=""
ELEVENLABS_API_KEY=""

# Cloudflare R2 / S3-compatible storage.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="loohii-assets"
R2_PUBLIC_URL=""
